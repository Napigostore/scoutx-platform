generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  REQUESTER
  SCOUT
  ADMIN
}

enum MissionCategory {
  STREET_CONDITIONS
  VENUE_STATUS
  LOCAL_EVENT
  PRODUCT_AVAILABILITY
  CROWD_DENSITY
  WEATHER_ON_SITE
  PHOTO_VERIFICATION
  GENERAL_OBSERVATION
}

enum MissionStatus {
  DRAFT
  OPEN
  MATCHED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum MissionUrgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ScoutAvailability {
  AVAILABLE
  BUSY
  OFFLINE
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  displayName      String
  role             UserRole
  avatarUrl        String?
  reliabilityScore Float    @default(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  scoutProfile     ScoutProfile?
  requestedMissions Mission[]      @relation("RequestedMissions")
  submissions      MissionSubmission[]

  @@map("users")
}

model Location {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  city        String
  country     String
  countryCode String  @db.Char(2)
  latitude    Float
  longitude   Float
  timezone    String

  missions Mission[]
  scouts   ScoutProfile[]

  @@map("locations")
}

model ScoutProfile {
  id                 String            @id @default(uuid()) @db.Uuid
  userId             String            @unique @db.Uuid
  displayName        String
  bio                String
  availability       ScoutAvailability @default(AVAILABLE)
  reliabilityScore   Float             @default(50)
  completedMissions  Int               @default(0)
  categories         MissionCategory[]
  tags               String[]
  homeLocationId     String            @db.Uuid
  currentLatitude    Float?
  currentLongitude   Float?
  maxRadiusMeters    Int               @default(5000)
  languages          String[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeLocation Location @relation(fields: [homeLocationId], references: [id])
  assignedMissions Mission[] @relation("AssignedScout")
  submissions  MissionSubmission[]

  @@map("scout_profiles")
}

model Mission {
  id              String          @id @default(uuid()) @db.Uuid
  title           String
  description     String
  category        MissionCategory
  status          MissionStatus   @default(DRAFT)
  urgency         MissionUrgency  @default(NORMAL)
  budgetCents     Int
  currency        String          @default("USD") @db.Char(3)
  locationId      String          @db.Uuid
  latitude        Float
  longitude       Float
  radiusMeters    Int             @default(1500)
  requesterId     String          @db.Uuid
  assignedScoutId String?         @db.Uuid
  requiredTags    String[]
  expiresAt       DateTime
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  location      Location           @relation(fields: [locationId], references: [id])
  requester     User               @relation("RequestedMissions", fields: [requesterId], references: [id])
  assignedScout ScoutProfile?      @relation("AssignedScout", fields: [assignedScoutId], references: [id])
  submissions   MissionSubmission[]

  @@index([status, expiresAt])
  @@index([locationId])
  @@index([requesterId])
  @@index([assignedScoutId])
  @@map("missions")
}

model MissionSubmission {
  id          String   @id @default(uuid()) @db.Uuid
  missionId   String   @db.Uuid
  scoutId     String   @db.Uuid
  userId      String   @db.Uuid
  summary     String
  mediaUrls   String[]
  observedAt  DateTime
  latitude    Float
  longitude   Float
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  mission Mission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  scout   ScoutProfile @relation(fields: [scoutId], references: [id])
  user    User         @relation(fields: [userId], references: [id])

  @@index([missionId])
  @@index([scoutId])
  @@index([userId])
  @@map("mission_submissions")
}

