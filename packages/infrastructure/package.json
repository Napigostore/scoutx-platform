{
  "name": "@scoutx/infrastructure",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@scoutx/domain": "workspace:*",
    "@scoutx/recommendation-engine": "workspace:*",
    "@scoutx/types": "workspace:*",
    "@scoutx/auth": "workspace:*"
  },
  "devDependencies": {
    "@scoutx/typescript-config": "workspace:*",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
